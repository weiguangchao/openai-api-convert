{
  "name": "openai-api-convert",
  "version": "0.0.1",
  "description": "OpenAI Responses API to Chat Completions bridge",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openai-api-convert": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "config.example.yaml",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-build-assets.mjs",
    "check": "tsc --noEmit",
    "start": "node dist/src/index.js start",
    "test": "npm run build && node dist/scripts/release-smoke.js",
    "test:unit": "npm run build && node --test dist/test/**/*.test.js",
    "test:codex-mixed-tools": "npm run build && node --test --test-name-pattern='Codex mixed-tools' dist/test/bridge.test.js",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.9.0"
  }
}
